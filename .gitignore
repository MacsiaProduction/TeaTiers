# ── Build outputs ───────────────────────────────────────────────────────────
build/
bin/
out/

# ── Gradle ──────────────────────────────────────────────────────────────────
.gradle/
# Keep the wrapper jar in VCS so CI can bootstrap Gradle without a pre-install.
!gradle/wrapper/gradle-wrapper.jar

# ── Kotlin ──────────────────────────────────────────────────────────────────
.kotlin/

# ── Android ─────────────────────────────────────────────────────────────────
*.apk
*.aab
*.ap_
*.dex
*.class
local.properties
.cxx/
captures/

# ── Secrets — never commit (rule 10-style / 50-secure) ────────────────────────
*.keystore
*.jks
*.p12
keystore.properties
secrets.properties
service-account*.json
.env
.env.*

# ── IDE / tooling ─────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.code-workspace

# ── Python (OCR sidecar) ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# JVM fatal-error dumps (transient build crashes)
hs_err_pid*.log
replay_pid*.log
