<?xml version="1.0" encoding="utf-8"?>
<!-- Languages offered by the in-app picker (#28) and the system per-app language settings on
     API 33+. Russian is the default/source locale; the en translation lands in M5. Chinese (zh)
     UI is deferred to the far future (decision #94) and is intentionally not offered. -->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="ru" />
    <locale android:name="en" />
</locale-config>
