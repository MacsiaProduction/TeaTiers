# OpenTofu CLI config: pull providers from Yandex's mirror. The OpenTofu/Terraform public
# registries lag the Yandex provider and registry.terraform.io is region-blocked from RU, so the
# mirror is the canonical source (plan.md §8, decision #18). Use it with:
#   export TF_CLI_CONFIG_FILE="$PWD/tofurc"   # run from infra/
#   tofu init
provider_installation {
  network_mirror {
    url = "https://terraform-mirror.yandexcloud.net/"
  }
}
