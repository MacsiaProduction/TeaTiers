# Caddy terminates TLS for the public domain and reverse-proxies to the server container on the
# private compose network. DOMAIN / ACME_EMAIL come from /opt/teatiers/.env. Caddy obtains and
# renews a Let's Encrypt certificate automatically (ports 80/443 must be reachable — they are).
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# Security headers (review 2026-06-19). TLS is always on (Caddy auto-HTTPS), so HSTS is safe.
	# No CSP: this host serves only JSON APIs (no HTML/JS), so a content policy adds nothing.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		# Don't advertise the edge software.
		-Server
	}

	# Cap request bodies at the edge so an oversized upload is rejected before it reaches the app
	# (the /teas/ocr image cap is 8 MB; 10 MB leaves multipart headroom). Defense-in-depth with the
	# server's multipart limit and the sidecar's own byte cap.
	request_body {
		max_size 10MB
	}

	# X-Forwarded-For (decision #98, re-verified #134): the backend keys its per-client rate limits off
	# the first XFF hop. Caddy v2 (2.7+) with NO `trusted_proxies` already OVERWRITES a client-supplied
	# X-Forwarded-For with the real client IP — VM-verified on caddy 2.11.4 that a spoofed value is
	# dropped, not appended (review N2 was a false positive, assuming pre-2.7 append behavior). The
	# `header_up` below pins that explicitly so the guarantee never depends on a Caddy-version default
	# (and survives a downgrade). The backend is also only reachable through Caddy (8080 unpublished in
	# prod). If a CDN is ever put in front of Caddy, add `trusted_proxies` for it and revisit this.
	reverse_proxy server:8080 {
		# Authoritatively set X-Forwarded-For to the real direct-client IP, dropping any client-supplied
		# value, so the per-client rate-limit key can't be spoofed (review N2 / decision #134).
		header_up X-Forwarded-For {http.request.remote.host}
		# Bound how long Caddy waits on the backend so a stuck upstream can't pin edge connections.
		# 30 s response header timeout covers the slowest synchronous path (a Wikidata resolve does
		# up to 2 attempts × ~11 s); LLM enrichment is dispatched in the background, not awaited.
		transport http {
			dial_timeout 5s
			response_header_timeout 30s
		}
	}
}
